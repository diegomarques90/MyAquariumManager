@model MyAquariumManager.Web.Models.Planta.DetalhesViewModel;
@using MyAquariumManager.Core.Enums;

@{
    ViewData["Title"] = "Detalhes da Planta";
}

<div class="mt-3 mb-3">
    <h4>DETALHES: @Model.Nome</h4>
</div>

<div class="container mt-3"></div>

<div class="row">
    <div class="col-12 col-sm-6 mt-2">
        <label><strong>Nome:</strong> @Model.Nome</label><br />
    </div>
    <div class="col-12 col-sm-6 mt-2">
        <label><strong>Nome Científico:</strong> @Model.NomeCientifico</label><br />
    </div>

    <div class="col-12 col-sm-6 mt-2">
        <label><strong>Local de Aquisição:</strong> @Model.LocalAquisicao</label><br />
    </div>
    <div class="col-12 col-sm-6 mt-2">
        <label><strong>Data de Aquisição:</strong> @Model.DataAquisicao </label><br />
    </div>

    <div class="separator"></div>

    <div class="col-12 col-sm-4 mt-2">
        <label><strong>Faixa de Tamanho:</strong> @Model.FaixaDeTamanho</label><br />
    </div>
    <div class="col-12 col-sm-4 mt-2">
        <label><strong>Tipo de Crescimento:</strong>
            @{
                switch (Model.TipoDeCrescimento)
                {
                    case TipoDeCrescimento.Lento:
                        @:Lento
                        break;
                    case TipoDeCrescimento.Moderado:
                        @:Moderado
                        break;
                    case TipoDeCrescimento.Rapido:
                        @:Rápido
                        break;
                }
            }
        </label><br />
    </div>
    <div class="col-12 col-sm-4 mt-2">
        <label><strong>Tipo de Iluminação:</strong>
            @{
                switch (Model.TipoDeIluminacao)
                {
                    case TipoDeIluminacao.Baixa:
                        @:Baixa
                        break;
                    case TipoDeIluminacao.Media:
                        @:Média
                        break;
                    case TipoDeIluminacao.Alta:
                        @:Alta
                        break;
                }
            }
        </label><br />
    </div>

    <div class="col-12 col-sm-4 mt-2">
        <label><strong>Faixa do PH:</strong> @Model.FaixaDoPH</label><br />
    </div>
    <div class="col-12 col-sm-4 mt-2">
        <label><strong>Faixa de Temperatura:</strong> @Model.FaixaDeTemperatura</label><br />
    </div>
    <div class="col-12 col-sm-4 mt-2">
        <label><strong>Nível de Cultivo:</strong> @Model.NivelDeCutivo</label><br />
    </div>

    <div class="col-12 col-sm-4 mt-2">
        <label>
            <strong>Tipo de Plantio:</strong>
            @{
                switch (Model.TipoDePlantio)
                {
                    case TipoDePlantio.Fixada:
                        @:Fixada
                        break;
                    case TipoDePlantio.Flutuante:
                        @:Flutuante
                        break;
                    case TipoDePlantio.Fundo:
                        @:Fundo
                        break;
                    case TipoDePlantio.Medio:
                        @:Médio
                        break;
                    case TipoDePlantio.Frontal:
                        @:Frontal
                        break;
                }
            }
        </label><br />
    </div>
    <div class="col-12 col-sm-4 mt-2">
        <label><strong>Forma de Reprodução:</strong> @Model.FormaDeReproducao</label><br />
    </div>
    <div class="col-12 col-sm-4 mt-2">
        <label><strong>Exige CO²:</strong> @Model.ExigeCO2</label><br />
    </div>

    <div class="separator"></div>

    <div class="col-12 mt-2">
        <label><strong>Informações Adicionais:</strong> @Model.InformacoesAdicionais</label>
    </div>
</div>

<div class="row">
    <div class="container d-flex justify-content-end">
        <a asp-action="Index" class="btn btn-outline-dark d-flex justify-content-center align-items-center mx-3">Voltar</a>
    </div>
</div>